{
  "name": "@localreader/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "pnpm prisma:generate && mkdir -p ../../data && RUST_LOG=debug DATABASE_URL=\"${DATABASE_URL:-file:../../../data/test.sqlite}\" prisma db push --force-reset --skip-generate --schema prisma/schema.prisma && DATABASE_URL=\"${DATABASE_URL:-file:../../data/test.sqlite}\" vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "mkdir -p ../../data && DATABASE_URL=\"${DATABASE_URL:-file:../../../data/localreader.sqlite}\" prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "mkdir -p ../../data && DATABASE_URL=\"${DATABASE_URL:-file:../../../data/localreader.sqlite}\" prisma migrate dev --schema prisma/schema.prisma --name init",
    "seed": "mkdir -p ../../data && DATABASE_URL=\"${DATABASE_URL:-file:../../data/localreader.sqlite}\" tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.3.0",
    "@fontsource-variable/vazirmatn": "^5.2.8",
    "@localreader/shared": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.3.2",
    "fastify": "^5.6.2",
    "jsdom": "^27.2.0",
    "marked": "^17.0.6",
    "pino": "^10.1.0",
    "playwright-core": "^1.60.0",
    "sanitize-html": "^2.17.0",
    "turndown": "^7.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "@types/sanitize-html": "^2.16.0",
    "@types/turndown": "^5.0.5",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "vitest": "^4.0.14"
  }
}
